{
  "name": "timezone.solar",
  "version": "1.1.0",
  "description": "Natural language timezone converter — timezone.solar",
  "author": "Jan Fasnacht",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/janfasnacht/timezone.solar.git"
  },
  "keywords": [
    "timezone",
    "converter",
    "natural-language",
    "react",
    "typescript"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/bundle-api.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "eval:generate": "tsx --env-file=.env.local scripts/generate-eval-queries.ts",
    "eval:compile": "tsx scripts/compile-eval-fixture.ts",
    "eval": "vitest run src/engine/parser-eval.test.ts",
    "icons:download": "npx tsx scripts/download-icons.ts"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/instrument-sans": "^5.2.8",
    "@vercel/og": "^0.8.6",
    "city-timezones": "^1.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.563.0",
    "luxon": "^3.7.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@fontsource/fraunces": "^5.2.9",
    "@tailwindcss/vite": "^4.1.18",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.6.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
